    {
      "parameters": {
        "jsCode": "const wh = $('상품등록 Webhook').first().json;\nlet body;\nif (Array.isArray(wh.body)) {\n  body = wh.body[0].body;\n} else {\n  body = wh.body || wh;\n}\nconst product = body.product || {};\nconst itemNo = (product.customProductCode || '').trim();\n\n// itemNo 없으면 소싱검토함 미통과 → skip\nif (!itemNo) return [];\n\nconst parsed = $('상품등록 데이터 파싱').first().json;\nconst regResult = $('소울스토어 상품등록').first().json;\nconst mall = '소울스토어';\nconst cafe24ProductNo = regResult.product.product_no;\nconst title = (parsed.soul || {}).product_name || parsed.product_name || '';\nconst thumb = (parsed.soul || {}).main_image || '';\nconst category = String((parsed.soul || {}).category_no || '');\nconst itemNo_mall = `${itemNo}_${mall}`;\n\nreturn [{ json: {\n  itemNo,\n  title,\n  category,\n  status: 'registered',\n  thumb,\n  mall,\n  cafe24ProductNo,\n  registered_at: new Date().toISOString(),\n  itemNo_mall\n} }];"
      },
